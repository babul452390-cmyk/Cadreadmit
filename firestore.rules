rules_version = '2';

// CadreAdmit — Firestore Security Rules
// Paste this into Firebase Console → Firestore → Rules → Publish.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdminEmail() {
      return isSignedIn() &&
        request.auth.token.email == 'babul452390@gmail.com';
    }

    function isAdminRole() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isAdmin() {
      return isAdminEmail() || isAdminRole();
    }

    // Users: own profile read/write; role & subscription only by admin.
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      // Create own profile on signup with role='user' (admin email may set admin)
      allow create: if isSignedIn() && request.auth.uid == uid &&
        (request.resource.data.role == 'user' || isAdminEmail());
      // Update own profile but NOT role/subscription unless admin
      allow update: if isSignedIn() && (
        (request.auth.uid == uid &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.subscription == resource.data.subscription) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Content — signed-in users can read; only admin writes.
    match /subjects/{id}   { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /questions/{id}  { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /modelTests/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /writtenTopics/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // Attempts — user creates own, reads own; admin reads all.
    match /attempts/{id} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // Written submissions
    match /writtenSubmissions/{id} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Payments — user creates own pending, reads own; admin approves.
    match /payments/{id} {
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // Settings — everyone (signed in) reads; only admin writes.
    match /settings/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
